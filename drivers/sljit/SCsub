Import('env')
Import('env_drivers')

env.Append(CPPFLAGS=['-DSLJIT_CONFIG_AUTO=1'])

env_drivers.Append(CPPFLAGS=['-DSLJIT_CONFIG_AUTO=1'])
if env['target'] == 'release':
	env.Append(CPPFLAGS=['-DSLJIT_DEBUG=0'])
	env_drivers.Append(CPPFLAGS=['-DSLJIT_DEBUG=0'])

env.drivers_sources+=["sljit/sljit_src/sljitLir.c"]

Export('env')
